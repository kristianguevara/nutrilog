# Copy to .env.local for local `vercel dev` (never commit real secrets)
OPENAI_API_KEY=
# Optional override; default in code is gpt-4o-mini (vision). Set when your org exposes a newer mini, e.g. gpt-5.4-mini
OPENAI_MODEL=

# Browser-only: force mock scan (no POST /api/food-scan). For `pnpm dev` without vercel dev.
# VITE_FOOD_SCAN_MOCK=true

# If `vercel dev` listens on a non-default host/port, point Vite's proxy at it (see vite.config.ts).
# VITE_VERCEL_DEV_URL=http://127.0.0.1:3000
