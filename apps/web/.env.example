# Copy to `.env` (gitignored). Never commit real secrets.

# OpenAI / Gemini (see repo docs for API routes)
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# Supabase (Vite: use VITE_ prefix — not NEXT_PUBLIC_)
# Project Settings → API: Project URL and anon / publishable key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Local auth: disable Confirm email + raise rate limits in Supabase — see docs/supabase-auth-dev.md

# Optional: proxy for `vercel dev` when not on http://127.0.0.1:3000
# VITE_VERCEL_DEV_URL=http://127.0.0.1:3000
