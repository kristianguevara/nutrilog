# Copy to .env.local for local `vercel dev` (never commit real secrets)
#
# Food scan provider: omit or `openai` (default) | `gemini` (or `google`)
# FOOD_SCAN_PROVIDER=gemini
#
# OpenAI (when FOOD_SCAN_PROVIDER is unset or openai)
OPENAI_API_KEY=
# Optional override; default in code is gpt-4o-mini (vision). Set when your org exposes a newer mini, e.g. gpt-5.4-mini
OPENAI_MODEL=
#
# Google Gemini (when FOOD_SCAN_PROVIDER=gemini)
# Get a key: https://aistudio.google.com/apikey — create/select a project → Create API key → paste below.
GEMINI_API_KEY=
# Optional; default is gemini-2.5-flash (vision). gemini-1.5-* IDs often 404 on current API — see https://ai.google.dev/gemini-api/docs/models
# GEMINI_MODEL=

# Browser-only: force mock scan (no POST /api/food-scan). For `pnpm dev` without vercel dev.
# VITE_FOOD_SCAN_MOCK=true

# Default: API runs on 5173 (`pnpm dev:api` from apps/web). Override only if you change the listen port.
# VITE_VERCEL_DEV_URL=http://127.0.0.1:5173
